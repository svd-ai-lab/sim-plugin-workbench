import clr
import os

# Write output to a known file since RunWB2 doesn't pipe stdout
output_path = os.path.join(os.environ.get("TEMP", "C:\\Temp"), "sim_wb_check.json")

info = {
    "workbench": True,
    "version": GetServerVersion() if 'GetServerVersion' in dir() else "unknown",
}

# Try to get version from Workbench API
try:
    info["version"] = str(GetServerVersion())
except:
    pass

import json
with open(output_path, "w") as f:
    f.write(json.dumps(info))
